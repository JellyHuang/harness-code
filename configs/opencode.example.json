{
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "INFO",
  "data": {
    "directory": "~/.hcode"
  },
  "provider": {
    "bailian-coding-plan": {
      "npm": "@ai-sdk/anthropic",
      "name": "Model Studio Coding Plan",
      "options": {
        "baseURL": "https://coding.dashscope.aliyuncs.com/apps/anthropic/v1",
        "apiKey": "sk-sp-xxx"
      },
      "models": {
        "qwen3.5-plus": {
          "name": "Qwen3.5 Plus",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 1024
            }
          }
        }
      }
    },
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Anthropic",
      "options": {
        "apiKey": "",
        "timeout": 300000
      },
      "models": {
        "claude-sonnet-4": {
          "name": "Claude 4 Sonnet",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI",
      "options": {
        "apiKey": "",
        "timeout": 300000
      }
    }
  },
  "agent": {
    "build": {
      "model": "anthropic/claude-sonnet-4",
      "description": "Default build agent for development work",
      "mode": "primary",
      "steps": 25,
      "permission": {
        "edit": "ask",
        "bash": "ask",
        "write": "allow",
        "read": "allow"
      }
    },
    "plan": {
      "model": "anthropic/claude-sonnet-4",
      "description": "Read-only agent for analysis and planning",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "write": "deny",
        "read": "allow"
      }
    }
  },
  "shell": {
    "path": "/bin/bash",
    "args": ["-l"]
  },
  "model": "anthropic/claude-sonnet-4",
  "small_model": "anthropic/claude-haiku-4",
  "default_agent": "build",
  "snapshot": true,
  "share": "manual",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "plugin": [
    "opencode-plugin-openspec"
  ]
}